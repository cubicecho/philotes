# ── Required in production ────────────────────────────────────────────────────

# Secret used to sign JWTs. Must be a long random string in production.
# Generate one with: openssl rand -hex 32
JWT_SECRET=change-me-to-a-long-random-string

# Public URL the app is served at. Used to build magic-link URLs in emails.
# For local Docker: http://localhost:3001
APP_URL=http://localhost:3001

# ── Optional ──────────────────────────────────────────────────────────────────

# Database connection. Defaults to an embedded PGlite database at /data/pgdata.
# Set to a postgres:// URL to use an external PostgreSQL instance instead.
# DATABASE_URL=postgres://user:password@host:5432/dbname

# Port the server listens on. Default: 3001
# PORT=3001

# Set to "production" in Docker (already set in the Dockerfile).
# NODE_ENV=production
